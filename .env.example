# ============================================================
# AI Image Classifier — Environment Variables
# ============================================================
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env   (Windows)
#                  OR:  cp .env.example .env      (Mac/Linux)
#   2. Fill in your values below
#   3. NEVER commit the .env file to Git (it's in .gitignore)
# ============================================================

# Flask secret key — change this to any random string
SECRET_KEY=change-this-to-something-random-like-abc123xyz789

# Email for the contact form (optional — app works without this)
# Get Gmail App Password: myaccount.google.com → Security → App Passwords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-gmail-app-password

# Hugging Face token (only needed if you want to upload models)
# Get from: huggingface.co/settings/tokens → New Token → Write role
HF_TOKEN=hf_your_token_here

# Hugging Face model repo (change to your own username if you retrain)
HF_MODEL_REPO=Vicky25july2003/ai-image-classifier-model

# Server settings (you can leave these as default)
PORT=2222
HOST=0.0.0.0
